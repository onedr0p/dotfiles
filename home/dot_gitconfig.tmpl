[user]
  name = {{ .name }}
  email = {{ index . "email" | default "devin@buhl.casa" }}
  {{- $machine := includeTemplate "machine" . }}
  {{- if eq $machine "termux" }}
  signingKey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIGzIUqlk6IxP55MutXhdKy1w76sfJOd9YFT58P5Vy/0B
  {{- else if or (eq $machine "truenas") (eq $machine "fedora") }}
  {{- /* Key file path, not the literal key: no ssh-agent assumed, so git signs with the on-disk private key. */}}
  signingKey = {{ .chezmoi.homeDir }}/.ssh/id_ed25519.pub
  {{- else }}
  signingKey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIJnRHFdQWqxfTRuioNM4G3vZyWQy18Xty1+vQV0qm/6G
  {{- end }}
[gpg]
  format = ssh
[format]
  signOff = true
[core]
  autocrlf = input
  editor = nano
  excludesfile = {{ .chezmoi.homeDir }}/.gitignore_global
[commit]
  gpgsign = true
[merge]
  ff = only
[pull]
  rebase = true
[fetch]
  prune = true
[status]
  submoduleSummary = false
[tag]
  forceSignAnnotated = true
[init]
  defaultBranch = main
[filter "lfs"]
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true
  clean = git-lfs clean -- %f
[url "ssh://git@github.com/"]
  pushInsteadOf = https://github.com/
[push]
  autoSetupRemote = true
