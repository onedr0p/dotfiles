{{- /* One of: macos, termux, truenas, fedora. Prompted at init; derived for configs that predate the prompt. */ -}}
{{- if hasKey . "machine" -}}
{{- .machine -}}
{{- else if contains "termux" .chezmoi.homeDir -}}
termux
{{- else if eq .chezmoi.os "darwin" -}}
macos
{{- else if eq (index .chezmoi.osRelease "id") "fedora" -}}
fedora
{{- else -}}
truenas
{{- end -}}
