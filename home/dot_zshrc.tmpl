export ZSH="{{ .chezmoi.homeDir }}/.oh-my-zsh"
ZSH_THEME=""
plugins=(fluxcd git kubectl mise)
[[ -r $ZSH/oh-my-zsh.sh ]] && source $ZSH/oh-my-zsh.sh

# Activate mise first: starship, lsd, bat, kubecolor, etc. are mise-managed,
# so they must be on PATH before the command -v guards below run.
command -v mise >/dev/null && eval "$(mise activate zsh)"

export GPG_TTY=$(tty)

command -v bat >/dev/null && alias cat='bat'
command -v chezmoi >/dev/null && alias cm='chezmoi'
command -v doggo >/dev/null && alias dig='doggo'
command -v just >/dev/null && alias j='just'
command -v lsd >/dev/null && alias ls='lsd'
command -v mise >/dev/null && alias ms='mise'
command -v terraform >/dev/null && alias tf='terraform'
alias k='kubectl'
alias gco='git checkout'
alias gpl='git pull --rebase --autostash'
alias gpf='git push --force-with-lease'

if command -v kubecolor >/dev/null; then
    kubectl() { command kubecolor "$@" }
fi

watch() {
    (( $# == 0 )) && return
    if command -v viddy >/dev/null; then
        command viddy --disable_auto_save --differences --interval 2 --shell zsh "$@"
    else
        command watch -x zsh -c "$*"
    fi
}

# commit TYPE[-SCOPE][!] SUMMARY [// BODY] -> signed-off conventional commit
commit() {
    emulate -L zsh
    if (( $# == 0 )); then
        local short
        short="$(curl -sL https://whatthecommit.com/index.txt)"
        git commit -s -m "chore: ${short}" -m "Commit generated by whatthecommit.com"
        return
    fi
    local title="$1"; shift
    local description="$*"
    if [[ -z "${description//[[:space:]]/}" ]]; then
        if command -v cowsay >/dev/null && command -v lolcat >/dev/null; then
            print "Whoops you are missing a commit message" | cowsay | lolcat
        else
            print "Whoops you are missing a commit message"
        fi
        return
    fi
    local short long type scope
    short="${description%%//*}"
    if [[ "$description" == *//* ]]; then
        long="${description#*//}"
    else
        long=""
    fi
    short="${short#"${short%%[![:space:]]*}"}"; short="${short%"${short##*[![:space:]]}"}"
    long="${long#"${long%%[![:space:]]*}"}"; long="${long%"${long##*[![:space:]]}"}"
    if [[ "$title" == *-* ]]; then
        type="${title%%-*}"
        scope="${title#*-}"
        title="${type}(${scope})"
        if [[ "$scope" == *! ]]; then
            scope="${scope%!}"
            title="${type}(${scope})!"
        fi
    fi
    if [[ -z "$long" ]]; then
        git commit -s -m "${title}: ${short}"
    else
        git commit -s -m "${title}: ${short}" -m "${long}"
    fi
}

command -v starship >/dev/null && eval "$(starship init zsh)"
command -v zoxide >/dev/null && eval "$(zoxide init zsh)"
command -v atuin >/dev/null && eval "$(atuin init zsh --disable-up-arrow)"
command -v kubectl-krew >/dev/null && path=("{{ .chezmoi.homeDir }}/.krew/bin" $path)
