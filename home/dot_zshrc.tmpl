{{- $machine := includeTemplate "machine" . -}}
{{- if eq $machine "truenas" }}
# fish can't be the login shell here (sealed rootfs, not in /etc/shells), so
# interactive sessions exec into it; `zsh` typed from fish still gets zsh.
if [[ -z "$ZSH_EXECUTION_STRING" && "$(ps -p $PPID -o comm= 2>/dev/null)" != "fish" ]] && command -v fish >/dev/null; then
    exec fish
fi
{{- end }}

export ZSH="{{ .chezmoi.homeDir }}/.oh-my-zsh"
ZSH_THEME=""
plugins=(fluxcd git kubectl)
[[ -r $ZSH/oh-my-zsh.sh ]] && source $ZSH/oh-my-zsh.sh

# Everything below is guaranteed by the mise config (installed via the
# chezmoi mise-install hook) and reachable through the shims dir that
# .zshenv puts on PATH, so no command existence checks are needed.
eval "$(mise activate zsh)"

export GPG_TTY=$(tty)

alias cat='bat'
alias cm='chezmoi'
alias j='just'
alias ls='lsd'
alias ms='mise'
alias k='kubectl'
alias gco='git checkout'
alias gpl='git pull --rebase --autostash'
alias gpf='git push --force-with-lease'

kubectl() { command kubecolor "$@" }

watch() {
    (( $# == 0 )) && return
    command viddy --disable_auto_save --differences --interval 2 --shell zsh "$@"
}

# commit TYPE[-SCOPE][!] SUMMARY [// BODY] -> signed-off conventional commit
commit() {
    emulate -L zsh
    if (( $# == 0 )); then
        local short
        short="$(curl -sL https://whatthecommit.com/index.txt)"
        git commit -s -m "chore: ${short}" -m "Commit generated by whatthecommit.com"
        return
    fi
    local title="$1"; shift
    local description="$*"
    if [[ -z "${description//[[:space:]]/}" ]]; then
        if command -v cowsay >/dev/null && command -v lolcat >/dev/null; then
            print "Whoops you are missing a commit message" | cowsay | lolcat
        else
            print "Whoops you are missing a commit message"
        fi
        return
    fi
    local short long type scope
    short="${description%%//*}"
    if [[ "$description" == *//* ]]; then
        long="${description#*//}"
    else
        long=""
    fi
    short="${short#"${short%%[![:space:]]*}"}"; short="${short%"${short##*[![:space:]]}"}"
    long="${long#"${long%%[![:space:]]*}"}"; long="${long%"${long##*[![:space:]]}"}"
    if [[ "$title" == *-* ]]; then
        type="${title%%-*}"
        scope="${title#*-}"
        title="${type}(${scope})"
        if [[ "$scope" == *! ]]; then
            scope="${scope%!}"
            title="${type}(${scope})!"
        fi
    fi
    if [[ -z "$long" ]]; then
        git commit -s -m "${title}: ${short}"
    else
        git commit -s -m "${title}: ${short}" -m "${long}"
    fi
}

eval "$(starship init zsh)"
eval "$(zoxide init zsh)"
eval "$(atuin init zsh --disable-up-arrow)"
